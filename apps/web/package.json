{
  "name": "@brika/store-web",
  "version": "0.1.0",
  "private": true,
  "description": "The Brika store web app: storefront plus the registry's /v1 API, on TanStack Start and Cloudflare Workers",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/store.git",
    "directory": "apps/web"
  },
  "license": "MIT",
  "author": "Brika Labs",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run db:migrate && wrangler deploy",
    "typecheck": "tsgo --noEmit",
    "e2e": "playwright test",
    "e2e:seed": "bun run e2e/seed.ts",
    "seed": "bun run scripts/seed.ts",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply brika-store --local",
    "db:migrate": "wrangler d1 migrations apply brika-store --remote",
    "db:setup:local": "bun run scripts/apply-registry-schema.ts"
  },
  "dependencies": {
    "@brika/clay": "^0.4.0",
    "@brika/di": "workspace:*",
    "@brika/env": "workspace:*",
    "@brika/registry-contract": "workspace:*",
    "@brika/registry-core": "workspace:*",
    "@brika/registry-runtime": "workspace:*",
    "@brika/router": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/store-db": "workspace:*",
    "@brika/tx": "workspace:*",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "better-auth": "^1.6.20",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.2",
    "@cloudflare/workers-types": "^4.20260613.1",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wrangler": "^4.99.0"
  }
}
