{
  "name": "@brika/registry",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Worker serving the Brika plugin registry: npm-compatible reads, GitHub-identity publish, and package management",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/store.git",
    "directory": "apps/registry"
  },
  "license": "MIT",
  "author": "Brika Labs",
  "scripts": {
    "dev": "wrangler dev --persist-to ../web/.wrangler/state",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "bun run db:migrate && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply brika-store --local",
    "db:migrate": "wrangler d1 migrations apply brika-store --remote",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@brika/env": "workspace:*",
    "@brika/registry-core": "workspace:*",
    "@brika/router": "workspace:*",
    "@brika/schema": "workspace:*",
    "@brika/store-db": "workspace:*",
    "@brika/tx": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.25",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
