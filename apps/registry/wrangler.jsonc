{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brika-registry",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-12",
  "compatibility_flags": ["nodejs_compat"],
  "observability": { "enabled": true },
  // registry.brika.dev is the only public origin for the npm protocol.
  "workers_dev": false,
  "preview_urls": false,
  "routes": [{ "pattern": "registry.brika.dev", "custom_domain": true }],
  // Shares the store's D1 (store + reg_* tables live together).
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "brika-store",
      "database_id": "fab2588d-5d17-405b-97d5-0a41e177b7d2"
    }
  ],
  // Immutable tarball bytes. Create with `wrangler r2 bucket create brika-registry-tarballs`.
  "r2_buckets": [{ "binding": "TARBALLS", "bucket_name": "brika-registry-tarballs" }]
}
