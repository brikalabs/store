{
  "name": "store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/store.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter @brika/store-web dev",
    "build": "bun run --filter @brika/store-web build",
    "deploy": "bun run --filter @brika/store-web deploy",
    "test": "bun test packages apps/registry apps/cli",
    "typecheck": "bun run --filter '*' typecheck",
    "check:no-em-dash": "bun run scripts/check-no-em-dash.ts",
    "lint": "bunx --bun biome check . && bun run check:no-em-dash"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.5",
    "typescript": "^6.0.3"
  }
}
