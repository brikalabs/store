{
  "name": "store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/brikalabs/store.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --filter @brika/store-web dev",
    "dev:registry": "bun run --filter @brika/registry dev",
    "cli": "BRIKA_REGISTRY=http://localhost:8787 bun apps/cli/src/index.ts",
    "build": "bun run --filter @brika/store-web build",
    "deploy": "bun run --filter @brika/store-web deploy",
    "test": "bun test packages apps/registry apps/cli apps/web/src architecture",
    "test:e2e": "bun run --filter @brika/store-web e2e",
    "typecheck": "bun run --filter '*' typecheck",
    "check:no-em-dash": "bun run scripts/check-no-em-dash.ts",
    "spec:lint": "bun run scripts/spec-lint.ts",
    "spec:index": "bun run scripts/gen-spec-index.ts",
    "spec:coverage": "bun run scripts/spec-coverage.ts",
    "spec:check": "bun run scripts/spec-lint.ts && bun run scripts/gen-spec-index.ts --check && bun run scripts/spec-coverage.ts",
    "markers": "bun run packages/markers/src/cli.ts",
    "unenforced": "bun run packages/markers/src/cli.ts --kind unenforced",
    "markers:vscode": "bun run --filter brika-markers build",
    "markers:vscode:install": "bun run --filter brika-markers install:editor",
    "lint": "bunx --bun biome check . && bun run check:no-em-dash",
    "sonar": "bunx --bun biome lint --config-path biome.sonar.jsonc --max-diagnostics=none .",
    "sonar:fix": "bunx --bun biome lint --write --config-path biome.sonar.jsonc --max-diagnostics=none ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@brika/archunit": "workspace:*",
    "@types/bun": "^1.3.5",
    "@typescript/native-preview": "^7.0.0-dev.20260615.1",
    "typescript": "^6.0.3"
  }
}
