{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "apps/**",
      "packages/**",
      "*.json",
      "!biome.json",
      "!**/node_modules",
      "!**/dist",
      "!**/coverage",
      "!**/routeTree.gen.ts",
      "!**/worker-configuration.d.ts",
      "!**/*.md"
    ]
  },
  "plugins": [
    "./biome-plugins/no-em-dash.grit",
    {
      "path": "./biome-plugins/boundaries-pure.grit",
      "includes": [
        "**/packages/registry-core/**",
        "**/packages/contract/**",
        "**/packages/schema/**",
        "**/packages/env/**"
      ]
    },
    {
      "path": "./biome-plugins/boundaries-client.grit",
      "includes": ["**/apps/web/src/components/**", "**/apps/web/src/lib/use-*.ts"]
    }
  ],
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "correctness": {
        "noUnusedImports": "error",
        "noUnusedVariables": "error"
      },
      "style": {
        "noNonNullAssertion": "error",
        "noParameterAssign": "error",
        "noUselessElse": "error",
        "useCollapsedElseIf": "error",
        "useConst": "error",
        "useExportType": "error",
        "useImportType": "error",
        "useNodejsImportProtocol": "error",
        "useNumberNamespace": "error",
        "useShorthandFunctionType": "error",
        "useTemplate": "error"
      },
      "suspicious": {
        "noExplicitAny": "error"
      },
      "complexity": {
        "noUselessFragments": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  }
}
