{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2023"],
    // `bun` (a Node types superset) supplies `bun:sqlite` + `node:async_hooks` used by
    // the test harness and @brika/tx; node builtins run on the Worker via `nodejs_compat`.
    "types": ["@cloudflare/workers-types", "bun"]
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts"]
}
